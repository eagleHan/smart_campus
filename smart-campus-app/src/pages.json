{
  "easycom": {
    "autoscan": true,
    "custom": {
      "^uni-(.*)": "@dcloudio/uni-ui/lib/uni-$1/uni-$1.vue"
    }
  },
  "pages": [
    {
      "path": "pages/login/index",
      "style": {
        "navigationBarTitleText": "登录",
        "navigationBarBackgroundColor": "#1677FF"
      }
    },
    {
      "path": "pages/home/index",
      "style": {
        "navigationBarTitleText": "首页"
      }
    },
    {
      "path": "pages/schedule/index",
      "style": {
        "navigationBarTitleText": "课表"
      }
    },
    {
      "path": "pages/attendance/index",
      "style": {
        "navigationBarTitleText": "考勤"
      }
    },
    {
      "path": "pages/leave/index",
      "style": {
        "navigationBarTitleText": "请假申请"
      }
    },
    {
      "path": "pages/notice/index",
      "style": {
        "navigationBarTitleText": "通知公告"
      }
    },
    {
      "path": "pages/approval/index",
      "style": {
        "navigationBarTitleText": "审批"
      }
    }
  ],
  "tabBar": {
    "color": "#999999",
    "selectedColor": "#1677FF",
    "borderStyle": "black",
    "list": [
      {
        "pagePath": "pages/home/index",
        "iconPath": "static/tabs/home.png",
        "selectedIconPath": "static/tabs/home-active.png",
        "text": "首页"
      },
      {
        "pagePath": "pages/schedule/index",
        "iconPath": "static/tabs/schedule.png",
        "selectedIconPath": "static/tabs/schedule-active.png",
        "text": "课表"
      },
      {
        "pagePath": "pages/notice/index",
        "iconPath": "static/tabs/notice.png",
        "selectedIconPath": "static/tabs/notice-active.png",
        "text": "通知"
      },
      {
        "pagePath": "pages/approval/index",
        "iconPath": "static/tabs/approval.png",
        "selectedIconPath": "static/tabs/approval-active.png",
        "text": "审批"
      }
    ]
  },
  "globalStyle": {
    "navigationBarTextStyle": "black",
    "navigationBarTitleText": "智慧校园",
    "navigationBarBackgroundColor": "#FFFFFF",
    "backgroundColor": "#F5F5F5"
  },
  "uniIdRouter": {}
}
